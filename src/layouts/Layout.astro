---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'FeriaApp - Gestión de Ferias y Bodega',
  description = 'Sistema integral para gestión de ferias comunitarias, inventario de bodega y seguimiento de ventas.',
  image = '/og-image.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://feriaapp-web.pages.dev');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#2f5d3a" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, canonicalURL)} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, canonicalURL)} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>

  <!-- Global Styles -->
  <style is:global>
    @import '../styles/global.css';
  </style>

  <!-- Inline critical styles -->
  <style is:inline>
    body {
      margin: 0;
      font-family: 'Inter', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      background-color: #f5f1e8;
      color: #112a46;
    }

    .page-loader {
      position: fixed;
      inset: 0;
      background: #f5f1e8;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .page-loader.hidden {
      opacity: 0;
      visibility: hidden;
    }

    .loader-spinner {
      width: 40px;
      height: 40px;
      border: 3px solid #e8e0d0;
      border-top-color: #2f5d3a;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>

<body>
  <!-- Page Loader -->
  <div class="page-loader" id="page-loader">
    <div class="loader-spinner"></div>
  </div>

  <slot />

  <script is:inline>
    // Ocultar loader cuando DOM este listo
    document.addEventListener('DOMContentLoaded', function() {
      const loader = document.getElementById('page-loader');
      if (loader) {
        setTimeout(() => loader.classList.add('hidden'), 100);
      }
    });

    // Smooth scroll para anchors
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>
</body>
</html>
