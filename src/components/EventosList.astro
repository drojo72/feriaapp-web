<script>
  const API_BASE = 'https://feriaapp-api.onrender.com';
  let eventosCache = [];

  // ✅ Mapeo de campos actualizado para API optimizada
  const mapEvento = (e) => ({
    id: e.id,
    nombre: e.nombre || e.lugar || 'Evento sin nombre',
    fecha: e.fecha,
    hora: e.hora || '',
    ubicacion: e.lugar || e.ubicacion || '',
    estado: e.estado || 'activo',
    total_ventas: e.total_recaudado || e.total_confirmado || e.total_calculado || 0,
    descripcion: e.notas || '',
    // Campos nuevos de campos redundantes
    canal: e.canal_venta_nombre || '',
    tipo_canal: e.canal_venta_tipo || '',
    vendedor: e.vendedor_nombre || '',
    total_calculado: e.total_calculado || 0,
    total_confirmado: e.total_confirmado || 0,
    diferencia: e.diferencia || 0,
    fecha_cierre: e.fecha_cierre || null
  });

  async function cargarEventos() {
    try {
      const res = await fetch(`${API_BASE}/eventos?limit=100`); // ✅ Endpoint optimizado
      if (!res.ok) throw new Error('Error cargando eventos');
      const raw = await res.json();
      eventosCache = raw.map(mapEvento);
      renderizar(eventosCache);
    } catch (e) {
      tbody.innerHTML = `<tr><td colspan="6" class="empty-state">Error: ${e.message}</td></tr>`;
    }
  }

  function renderizar(lista) {
    const texto = filtroTexto.value.toLowerCase();
    const estado = filtroEstado.value;
    const filtrados = lista.filter(ev => {
      const matchTexto = !texto || (ev.nombre?.toLowerCase().includes(texto) || ev.ubicacion?.toLowerCase().includes(texto));
      const matchEstado = !estado || ev.estado === estado;
      return matchTexto && matchEstado;
    });

    if (filtrados.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6" class="empty-state">No hay eventos</td></tr>`;
      return;
    }

    tbody.innerHTML = filtrados.map(ev => {
      // ✅ Badge de estado mejorado
      const estadoBadge = {
        'activo': 'badge-activo',
        'cerrado': 'badge-cerrado',
        'programado': 'badge-programado'
      }[ev.estado] || 'badge-activo';

      // ✅ Mostrar información de canal
      const canalInfo = ev.canal ? `<br><small style="color: var(--color-muted);">${escapeHtml(ev.canal)} ${ev.tipo_canal ? `(${ev.tipo_canal})` : ''}</small>` : '';

      return `
      <tr data-id="${ev.id}">
        <td>
          <strong>${escapeHtml(ev.nombre)}</strong>
          ${canalInfo}
        </td>
        <td>${formatearFecha(ev.fecha)} ${ev.hora || ''}</td>
        <td>${escapeHtml(ev.ubicacion || '-')}</td>
        <td><span class="badge ${estadoBadge}">${ev.estado}</span></td>
        <td>$${Number(ev.total_ventas || 0).toLocaleString()}</td>
        <td>
          <button class="btn-icon btn-ver" title="Ver detalle" data-id="${ev.id}">👁️</button>
          <button class="btn-icon btn-editar" title="Editar" data-id="${ev.id}">✏️</button>
        </td>
      </tr>`;
    }).join('');

    // ✅ Eventos con delegación (más eficiente)
    tbody.querySelectorAll('.btn-ver').forEach(btn => {
      btn.addEventListener('click', () => verEvento(btn.dataset.id));
    });
    tbody.querySelectorAll('.btn-editar').forEach(btn => {
      btn.addEventListener('click', () => abrirEditar(btn.dataset.id));
    });
  }

  async function verEvento(id) {
    try {
      const res = await fetch(`${API_BASE}/eventos/${id}/resumen`);
      if (!res.ok) throw new Error('Error cargando resumen');
      const data = await res.json();
      // Mostrar modal con resumen
      mostrarResumen(data);
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  function mostrarResumen(data) {
    const content = document.getElementById('venta-detalle-content');
    if (!content) return;
    content.innerHTML = `
      <div class="resumen-evento">
        <p><strong>Evento:</strong> ${escapeHtml(data.evento?.nombre || '')}</p>
        <p><strong>Fecha:</strong> ${formatearFecha(data.evento?.fecha)}</p>
        <p><strong>Estado:</strong> ${data.evento?.estado || ''}</p>
        <hr>
        <div class="stats-grid">
          <div><strong>Total Ventas:</strong> $${Number(data.totales?.total_recaudado || 0).toLocaleString()}</div>
          <div><strong>Transacciones:</strong> ${data.totales?.total_ventas || 0}</div>
          <div><strong>Rebajas:</strong> $${Number(data.totales?.total_rebajas || 0).toLocaleString()}</div>
        </div>
        ${data.productos?.length ? `
          <hr>
          <h4>Productos vendidos</h4>
          ${data.productos.map(p => `
            <div class="linea-item">
              <span class="linea-nombre">${escapeHtml(p.nombre || 'Sin nombre')}</span>
              <span>${p.cantidad_vendida || 0} uds.</span>
              <span class="linea-precio">$${Number(p.total_recaudado || 0).toLocaleString()}</span>
            </div>
          `).join('')}
        ` : ''}
      </div>
    `;
    document.getElementById('modal-venta-title').textContent = 'Resumen Evento';
    modal.showModal();
  }

  // ... resto del código ...
</script>
