---
import BrandLogo from './BrandLogo.astro';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/#features', label: 'Funciones' },
  { href: '/#how-it-works', label: 'Cómo Funciona' },
  { href: '/admin', label: 'Admin', highlight: true }
];
---

<header class={`site-header ${transparent ? 'site-header--transparent' : ''}`} id="site-header">
  <div class="container">
    <div class="site-header__inner">
      <BrandLogo size="sm" showTagline={false} />

      <nav class="site-header__nav" aria-label="Navegación principal">
        <ul class="site-header__nav-list">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`site-header__nav-link ${link.highlight ? 'site-header__nav-link--highlight' : ''}`}
                aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <button
        class="site-header__mobile-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-toggle"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="container">
      <ul class="mobile-menu__list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="mobile-menu__link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(245, 241, 232, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
    height: var(--header-height);
  }

  .site-header--transparent {
    background-color: transparent;
    backdrop-filter: none;
    border-bottom: none;
  }

  .site-header--scrolled {
    box-shadow: var(--shadow-md);
    background-color: rgba(245, 241, 232, 0.98);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }

  .site-header__nav {
    display: none;
  }

  @media (min-width: 768px) {
    .site-header__nav {
      display: block;
    }
  }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--feria-navy);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .site-header__nav-link:hover {
    background-color: rgba(47, 93, 58, 0.08);
    color: var(--feria-bosque);
    text-decoration: none;
  }

  .site-header__nav-link[aria-current="page"] {
    background-color: rgba(47, 93, 58, 0.12);
    color: var(--feria-bosque);
    font-weight: 600;
  }

  .site-header__nav-link--highlight {
    background-color: var(--feria-bosque);
    color: white;
    font-weight: 600;
  }

  .site-header__nav-link--highlight:hover {
    background-color: var(--feria-bosque-light);
    color: white;
  }

  .site-header__mobile-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .site-header__mobile-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--feria-navy);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .site-header__mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .site-header__mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .site-header__mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background-color: var(--feria-crema);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu.is-open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: var(--space-4) 0;
  }

  .mobile-menu__link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--feria-navy);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .mobile-menu__link:hover {
    background-color: rgba(47, 93, 58, 0.08);
    color: var(--feria-bosque);
  }
</style>

<script is:inline>
  (function() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');

    // Scroll shadow
    let lastScroll = 0;
    window.addEventListener('scroll', function() {
      const currentScroll = window.pageYOffset;
      if (currentScroll > 10) {
        header.classList.add('site-header--scrolled');
      } else {
        header.classList.remove('site-header--scrolled');
      }
      lastScroll = currentScroll;
    });

    // Mobile menu toggle
    if (toggle && menu) {
      toggle.addEventListener('click', function() {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', !isOpen);
        menu.setAttribute('aria-hidden', isOpen);
        menu.classList.toggle('is-open', !isOpen);
      });

      // Cerrar menu al hacer click en un link
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', function() {
          toggle.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
          menu.classList.remove('is-open');
        });
      });
    }
  })();
</script>
