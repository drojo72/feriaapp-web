---
const API_BASE = 'https://feriaapp-api.onrender.com';
---

<!-- ... mismo HTML hasta la sección de etiquetas ... -->

<div class="form-section">
  <h4>📖 Historia del Producto</h4>
  <div class="form-group">
    <label for="prod-historia">Historia / Origen</label>
    <textarea id="prod-historia" rows="3" placeholder="Ej: Donación de familia en La Dehesa. Ropa de nieta que creció rápido, usado solo 2 veces."></textarea>
    <small style="color: var(--color-muted); font-size: var(--text-xs);">Cada prenda tiene una historia. Esto conecta con el comprador.</small>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="prod-ubicacion">Ubicación de origen</label>
      <input type="text" id="prod-ubicacion" placeholder="Ej: La Dehesa, Ñuñoa, Talca..."/>
    </div>
    <div class="form-group">
      <label for="prod-motivo">Motivo de donación</label>
      <select id="prod-motivo">
        <option value="">Seleccionar...</option>
        <option value="renovacion">Renovación de clóset</option>
        <option value="herencia">Herencia familiar</option>
        <option value="limpieza">Limpieza / Mudanza</option>
        <option value="viaje">Viaje / Mudanza al sur</option>
        <option value="crecimiento">Crecimiento (bebé/niño)</option>
        <option value="cambio_gustos">Cambio de gustos</option>
        <option value="otro">Otro</option>
      </select>
    </div>
  </div>
</div>

<!-- ... resto del formulario ... -->

<script>
  // ... código existente ...

  async function cargarProducto(id) {
    try {
      const res = await fetch(`${API_BASE}/productos/bodega/${id}`);
      const p = await res.json();
      // ... campos existentes ...
      document.getElementById('prod-historia').value = p.historia_origen || '';
      document.getElementById('prod-ubicacion').value = p.historia_ubicacion || '';
      document.getElementById('prod-motivo').value = p.historia_motivo || '';
    } catch (e) { alert('Error cargando producto: ' + e.message); }
  }

  document.getElementById('form-producto').addEventListener('submit', async (e) => {
    e.preventDefault();
    const payload = {
      // ... campos existentes ...
      historia_origen: document.getElementById('prod-historia').value || null,
      historia_ubicacion: document.getElementById('prod-ubicacion').value || null,
      historia_motivo: document.getElementById('prod-motivo').value || null
    };
    // ... resto del submit ...
  });
</script>
