---
const API_BASE = '/api';
---

<script>
  const API_BASE = '/api';
  let ventasCache = [];
  let eventosCache = [];

  // ✅ Mapeo de campos actualizado para API optimizada
  const mapVenta = (v) => ({
    id: v.id,
    fecha: v.timestamp_local || v.fecha || v.evento_fecha,
    evento_id: v.evento_feria_id,
    evento_nombre: v.evento_lugar || v.evento_nombre || '',
    evento_estado: v.evento_estado || '',
    total: v.total_venta || v.precio_final_total || 0,
    medio_pago: v.forma_pago || 'efectivo',
    notas: v.notas || '',
    vendedor: v.vendedor_nombre || '',
    lineas: v.lineas || [],
    sync_estado: v.sync_estado || 'sincronizado'
  });

  async function cargarDatos() {
    try {
      const [resV, resE] = await Promise.all([
        fetch(`${API_BASE}/ventas?limit=200`), // ✅ Endpoint optimizado
        fetch(`${API_BASE}/eventos?limit=50`)
      ]);
      const rawVentas = await resV.json();
      ventasCache = rawVentas.map(mapVenta);
      eventosCache = await resE.json();

      // ... filtros y renderizado ...
    } catch (e) {
      tbody.innerHTML = `<tr><td colspan="7" class="empty-state">Error: ${e.message}</td></tr>`;
    }
  }

  function renderizar(lista) {
    // ... filtros ...

    tbody.innerHTML = filtrados.map(v => {
      const ev = eventosCache.find(e => e.id === v.evento_id);
      const numProductos = v.lineas?.length || 0;

      // ✅ Badge de método de pago
      const metodoClass = {
        'efectivo': 'badge-efectivo',
        'transferencia': 'badge-transferencia',
        'debito': 'badge-debito',
        'credito': 'badge-credito'
      }[v.medio_pago] || 'badge-efectivo';

      // ✅ Nota de sync
      const syncBadge = v.sync_estado === 'pendiente'
        ? '<span class="nota-reconstruido">🔄 Pendiente</span>'
        : '';

      return `
      <tr data-id="${v.id}">
        <td>${formatearFecha(v.fecha)}</td>
        <td>${escapeHtml(ev?.nombre || v.evento_nombre || '—')}</td>
        <td>${numProductos} ítem${numProductos !== 1 ? 's' : ''}</td>
        <td>$${Number(v.total || 0).toLocaleString()}</td>
        <td><span class="badge-metodo ${metodoClass}">${v.medio_pago}</span></td>
        <td>
          <small>${escapeHtml((v.notas || '').substring(0, 40))}</small>
          ${syncBadge}
        </td>
        <td><button class="btn-icon btn-ver" title="Ver detalle" data-id="${v.id}">👁️</button></td>
      </tr>`;
    }).join('');
  }
</script>
