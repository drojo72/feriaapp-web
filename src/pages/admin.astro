---
import Layout from '../layouts/Layout.astro';

const API_BASE = 'https://feriaapp-api.onrender.com';
---

<Layout title="FeriaApp - Panel Administrativo">
  <div id="admin-app">
    <!-- Loading -->
    <div id="admin-loading" class="admin-loading">
      <div class="loader-spinner"></div>
      <p>Cargando panel...</p>
    </div>

    <!-- Login -->
    <div id="admin-login" class="admin-login hidden">
      <div class="admin-login__card">
        <div class="admin-login__brand">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4L4 20h40L24 4z" fill="var(--feria-salvia)" opacity="0.9"/>
            <path d="M24 4L14 20h20L24 4z" fill="var(--feria-bosque)"/>
            <rect x="8" y="20" width="3" height="20" rx="1" fill="var(--feria-tierra)"/>
            <rect x="37" y="20" width="3" height="20" rx="1" fill="var(--feria-tierra)"/>
            <rect x="4" y="38" width="40" height="4" rx="2" fill="var(--feria-tierra-dark)"/>
            <circle cx="24" cy="14" r="3" fill="var(--feria-crema)"/>
          </svg>
          <h1>FeriaApp</h1>
          <p>Panel Administrativo</p>
        </div>
        <form id="login-form" class="admin-login__form">
          <div class="form-group">
            <label for="login-email">Email</label>
            <input type="email" id="login-email" name="email" placeholder="tu@email.com" required autocomplete="email"/>
          </div>
          <div class="form-group">
            <label for="login-password">Contraseña</label>
            <input type="password" id="login-password" name="password" placeholder="••••••••" required autocomplete="current-password"/>
          </div>
          <div id="login-error" class="login-error hidden"></div>
          <button type="submit" class="btn btn-primary btn-lg" style="width:100%">
            <span class="btn-text">Iniciar Sesión</span>
            <span class="btn-spinner hidden"></span>
          </button>
        </form>
        <p class="admin-login__hint"><a href="/">← Volver al inicio</a></p>
      </div>
    </div>

    <!-- Dashboard -->
    <div id="admin-dashboard" class="admin-dashboard hidden">
      <aside class="admin-sidebar" id="admin-sidebar">
        <div class="admin-sidebar__header">
          <a href="/" class="admin-sidebar__brand">
            <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 4L4 20h40L24 4z" fill="var(--feria-salvia)" opacity="0.9"/>
              <path d="M24 4L14 20h20L24 4z" fill="var(--feria-bosque)"/>
              <rect x="8" y="20" width="3" height="20" rx="1" fill="var(--feria-tierra)"/>
              <rect x="37" y="20" width="3" height="20" rx="1" fill="var(--feria-tierra)"/>
              <rect x="4" y="38" width="40" height="4" rx="2" fill="var(--feria-tierra-dark)"/>
              <circle cx="24" cy="14" r="3" fill="var(--feria-crema)"/>
            </svg>
            <span>FeriaApp</span>
          </a>
          <button class="admin-sidebar__close" id="sidebar-close" aria-label="Cerrar menú">×</button>
        </div>
        <nav class="admin-sidebar__nav" aria-label="Navegación admin">
          <ul>
            <li><button class="nav-item active" data-view="resumen" aria-current="page">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Resumen
            </button></li>
            <li><button class="nav-item" data-view="eventos">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Eventos
            </button></li>
            <li><button class="nav-item" data-view="ventas">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              Ventas
            </button></li>
            <li><button class="nav-item" data-view="bodega">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              Bodega
            </button></li>
            <li><button class="nav-item" data-view="historico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Histórico
            </button></li>
          </ul>
        </nav>
        <div class="admin-sidebar__footer">
          <div class="admin-sidebar__user">
            <div class="user-avatar" id="user-avatar">A</div>
            <div class="user-info">
              <span class="user-name" id="user-name">Admin</span>
              <span class="user-role">Administrador</span>
            </div>
          </div>
          <button class="btn-logout" id="btn-logout">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Cerrar Sesión
          </button>
        </div>
      </aside>

      <main class="admin-main">
        <header class="admin-topbar">
          <button class="admin-topbar__menu" id="sidebar-toggle" aria-label="Abrir menú">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <h2 class="admin-topbar__title" id="view-title">Resumen</h2>
          <div class="admin-topbar__actions">
            <span class="api-status" id="api-status">
              <span class="status-dot"></span>
              Conectado
            </span>
          </div>
        </header>

        <div class="admin-views">
          <!-- ============================================================ -->
          <!-- VIEW: RESUMEN -->
          <!-- ============================================================ -->
          <div class="admin-view" id="view-resumen">
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-card__icon" style="background:rgba(47,93,58,0.1);color:var(--feria-bosque)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="stat-card__content">
                  <span class="stat-card__value" id="stat-eventos">--</span>
                  <span class="stat-card__label">Eventos Activos</span>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-card__icon" style="background:rgba(138,166,122,0.15);color:var(--feria-salvia-dark)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                </div>
                <div class="stat-card__content">
                  <span class="stat-card__value" id="stat-bodega">--</span>
                  <span class="stat-card__label">Productos en Bodega</span>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-card__icon" style="background:rgba(17,42,70,0.1);color:var(--feria-navy)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <div class="stat-card__content">
                  <span class="stat-card__value" id="stat-ventas">--</span>
                  <span class="stat-card__label">Ventas del Mes</span>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-card__icon" style="background:rgba(123,90,60,0.15);color:var(--feria-tierra-dark)">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
                </div>
                <div class="stat-card__content">
                  <span class="stat-card__value" id="stat-ingresos">--</span>
                  <span class="stat-card__label">Ingresos del Mes</span>
                </div>
              </div>
            </div>

            <div class="dashboard-sections">
              <div class="dashboard-section">
                <div class="section-header-bar">
                  <h3>Eventos Recientes</h3>
                  <button class="btn btn-sm btn-outline" data-action="ver-eventos">Ver Todos</button>
                </div>
                <div class="table-wrapper">
                  <table>
                    <thead><tr><th>Nombre</th><th>Fecha</th><th>Estado</th><th>Ventas</th></tr></thead>
                    <tbody id="resumen-eventos-tbody"><tr><td colspan="4" class="empty-state">Cargando...</td></tr></tbody>
                  </table>
                </div>
              </div>
              <div class="dashboard-section">
                <div class="section-header-bar">
                  <h3>Ventas Recientes</h3>
                  <button class="btn btn-sm btn-outline" data-action="ver-ventas">Ver Todas</button>
                </div>
                <div class="table-wrapper">
                  <table>
                    <thead><tr><th>Fecha</th><th>Evento</th><th>Total</th><th>Items</th></tr></thead>
                    <tbody id="resumen-ventas-tbody"><tr><td colspan="4" class="empty-state">Cargando...</td></tr></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <!-- ============================================================ -->
          <!-- VIEW: EVENTOS -->
          <!-- ============================================================ -->
          <div class="admin-view hidden" id="view-eventos">
            <div class="view-header">
              <h3>Gestión de Eventos</h3>
              <button class="btn btn-primary btn-sm" id="btn-nuevo-evento">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Nuevo Evento
              </button>
            </div>
            <div class="filters-bar">
              <input type="text" id="filtro-eventos" placeholder="Buscar eventos..." class="filter-input"/>
              <select id="filtro-estado" class="filter-select">
                <option value="">Todos los estados</option>
                <option value="activo">Activo</option>
                <option value="cerrado">Cerrado</option>
                <option value="programado">Programado</option>
              </select>
            </div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Nombre</th><th>Fecha</th><th>Ubicación</th><th>Estado</th><th>Ventas</th><th>Acciones</th></tr></thead>
                <tbody id="eventos-tbody"><tr><td colspan="6" class="empty-state">Cargando eventos...</td></tr></tbody>
              </table>
            </div>
          </div>

          <!-- ============================================================ -->
          <!-- VIEW: VENTAS -->
          <!-- ============================================================ -->
          <div class="admin-view hidden" id="view-ventas">
            <div class="view-header">
              <h3>Registro de Ventas</h3>
              <button class="btn btn-primary btn-sm" id="btn-nueva-venta">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Registrar Venta
              </button>
            </div>
            <div class="filters-bar">
              <input type="text" id="filtro-ventas" placeholder="Buscar ventas..." class="filter-input"/>
              <select id="filtro-evento-venta" class="filter-select"><option value="">Todos los eventos</option></select>
              <input type="date" id="filtro-fecha-desde" class="filter-input" style="max-width:150px"/>
              <input type="date" id="filtro-fecha-hasta" class="filter-input" style="max-width:150px"/>
            </div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>ID</th><th>Fecha</th><th>Evento</th><th>Items</th><th>Total</th><th>Método</th><th>Notas</th></tr></thead>
                <tbody id="ventas-tbody"><tr><td colspan="7" class="empty-state">Cargando ventas...</td></tr></tbody>
              </table>
            </div>
          </div>

          <!-- ============================================================ -->
          <!-- VIEW: BODEGA -->
          <!-- ============================================================ -->
          <div class="admin-view hidden" id="view-bodega">
            <div class="view-header">
              <h3>Inventario de Bodega</h3>
              <button class="btn btn-primary btn-sm" id="btn-nuevo-producto">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Nuevo Producto
              </button>
            </div>
            <div class="filters-bar">
              <input type="text" id="filtro-bodega" placeholder="Buscar productos..." class="filter-input"/>
              <select id="filtro-categoria" class="filter-select">
                <option value="">Todas las categorías</option>
                <option value="ropa">Ropa</option>
                <option value="alimentos">Alimentos</option>
                <option value="artesanias">Artesanías</option>
                <option value="otros">Otros</option>
              </select>
              <select id="filtro-stock" class="filter-select">
                <option value="">Todo el stock</option>
                <option value="bajo">Stock Bajo (&lt;5)</option>
                <option value="agotado">Agotado</option>
              </select>
            </div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Código</th><th>Nombre</th><th>Categoría</th><th>Stock</th><th>Precio</th><th>Estado</th><th>Acciones</th></tr></thead>
                <tbody id="bodega-tbody"><tr><td colspan="7" class="empty-state">Cargando inventario...</td></tr></tbody>
              </table>
            </div>
          </div>

          <!-- ============================================================ -->
          <!-- VIEW: HISTÓRICO / AUDITORÍA -->
          <!-- ============================================================ -->
          <div class="admin-view hidden" id="view-historico">
            <div class="view-header">
              <h3>📊 Histórico y Auditoría</h3>
              <div style="display:flex;gap:8px;">
                <button class="btn btn-sm btn-outline" id="btn-refresh-auditoria">🔄 Refrescar</button>
                <button class="btn btn-sm btn-primary" id="btn-exportar-auditoria">📥 Exportar</button>
              </div>
            </div>

            <!-- Tabs internos del histórico -->
            <div class="tabs-bar historico-tabs">
              <button class="tab-btn active" data-tab="auditoria">🔍 Auditoría</button>
              <button class="tab-btn" data-tab="eventos-cerrados">📋 Eventos Cerrados</button>
              <button class="tab-btn" data-tab="flujos">🔄 Flujos de Productos</button>
            </div>

            <!-- Panel: Auditoría -->
            <div class="tab-panel active" id="panel-auditoria">
              <div class="panel-header">
                <div class="filters-bar">
                  <input type="text" id="filtro-auditoria" placeholder="Buscar en auditoría..." class="filter-input"/>
                  <select id="filtro-auditoria-tipo" class="filter-select">
                    <option value="">Todos los tipos</option>
                    <option value="reabrir">🔓 Reapertura</option>
                    <option value="modificar">✏️ Modificación</option>
                    <option value="stock">📦 Ajuste de stock</option>
                    <option value="producto">🏷️ Cambio de producto</option>
                  </select>
                  <input type="date" id="filtro-auditoria-desde" class="filter-input" style="max-width:150px"/>
                  <input type="date" id="filtro-auditoria-hasta" class="filter-input" style="max-width:150px"/>
                </div>
              </div>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Fecha</th>
                      <th>Tipo</th>
                      <th>Usuario</th>
                      <th>Detalle</th>
                      <th>Justificación</th>
                    </tr>
                  </thead>
                  <tbody id="historico-auditoria-tbody">
                    <tr><td colspan="5" class="empty-state">Cargando auditoría...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Panel: Eventos Cerrados -->
            <div class="tab-panel hidden" id="panel-eventos-cerrados">
              <div class="panel-header">
                <div class="filters-bar">
                  <input type="text" id="filtro-eventos-cerrados" placeholder="Buscar..." class="filter-input"/>
                  <input type="date" id="filtro-eventos-desde" class="filter-input" style="max-width:150px"/>
                  <input type="date" id="filtro-eventos-hasta" class="filter-input" style="max-width:150px"/>
                </div>
              </div>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Evento</th>
                      <th>Fecha</th>
                      <th>Total Calculado</th>
                      <th>Total Confirmado</th>
                      <th>Diferencia</th>
                      <th>Fecha Cierre</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody id="historico-eventos-tbody">
                    <tr><td colspan="7" class="empty-state">Cargando eventos cerrados...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Panel: Flujos de Productos -->
            <div class="tab-panel hidden" id="panel-flujos">
              <div class="panel-header">
                <div class="filters-bar">
                  <input type="text" id="filtro-flujos" placeholder="Buscar producto..." class="filter-input"/>
                  <select id="filtro-flujo-tipo" class="filter-select">
                    <option value="">Todos los flujos</option>
                    <option value="boutique">→ Online</option>
                    <option value="feria">→ Feria</option>
                    <option value="donacion">→ Donación</option>
                    <option value="retazo">→ Retazo</option>
                  </select>
                  <select id="filtro-flujo-estado" class="filter-select">
                    <option value="">Todos los estados</option>
                    <option value="disponible">Disponible</option>
                    <option value="vendido">Vendido</option>
                    <option value="reservado">Reservado</option>
                    <option value="donado">Donado</option>
                    <option value="retazo">Retazo</option>
                  </select>
                </div>
              </div>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Producto</th>
                      <th>Flujo</th>
                      <th>Fecha</th>
                      <th>Motivo</th>
                      <th>Evaluado por</th>
                      <th>Historia</th>
                    </tr>
                  </thead>
                  <tbody id="historico-flujos-tbody">
                    <tr><td colspan="6" class="empty-state">Cargando flujos...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </main>

      <div class="admin-overlay" id="admin-overlay"></div>
    </div>
  </div>

  <!-- ============================================================ -->
  <!-- MODALES -->
  <!-- ============================================================ -->

  <!-- Modal: Evento -->
  <dialog class="admin-modal" id="modal-evento">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-evento-title">Nuevo Evento</h3>
        <button class="modal-close" data-close-modal>&times;</button>
      </div>
      <form id="form-evento" class="modal-form">
        <input type="hidden" id="evento-id"/>
        <div class="form-group">
          <label for="evento-nombre">Nombre del Evento *</label>
          <input type="text" id="evento-nombre" required placeholder="Ej: Feria Primavera 2026"/>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="evento-fecha">Fecha *</label>
            <input type="date" id="evento-fecha" required/>
          </div>
          <div class="form-group">
            <label for="evento-hora">Hora</label>
            <input type="time" id="evento-hora"/>
          </div>
        </div>
        <div class="form-group">
          <label for="evento-ubicacion">Ubicación</label>
          <input type="text" id="evento-ubicacion" placeholder="Ej: Plaza Central, Santiago"/>
        </div>
        <div class="form-group">
          <label for="evento-descripcion">Descripción</label>
          <textarea id="evento-descripcion" rows="3" placeholder="Detalles del evento..."></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" data-close-modal>Cancelar</button>
          <button type="submit" class="btn btn-primary"><span class="btn-text">Guardar</span><span class="btn-spinner hidden"></span></button>
        </div>
      </form>
    </div>
  </dialog>

  <!-- Modal: Reabrir Evento (con justificación obligatoria) -->
  <dialog class="admin-modal" id="modal-reabrir">
    <div class="modal-content" style="max-width: 500px;">
      <div class="modal-header">
        <h3>🔓 Reabrir Evento</h3>
        <button class="modal-close" data-close-modal>&times;</button>
      </div>
      <form id="form-reabrir" class="modal-form">
        <input type="hidden" id="reabrir-evento-id"/>
        <div class="form-group">
          <label>Evento</label>
          <input type="text" id="reabrir-evento-nombre" readonly style="background:var(--color-muted-bg);"/>
        </div>
        <div class="form-group">
          <label for="reabrir-motivo">Motivo de Reapertura *</label>
          <textarea id="reabrir-motivo" rows="3" placeholder="Explicar detalladamente por qué se reabre el evento..." required></textarea>
          <small style="color: var(--color-muted);">Esta justificación quedará registrada en el historial de auditoría.</small>
        </div>
        <div class="form-group">
          <label for="reabrir-nota-adicional">Nota adicional (opcional)</label>
          <input type="text" id="reabrir-nota-adicional" placeholder="Ej: Se detectó venta no registrada"/>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" data-close-modal>Cancelar</button>
          <button type="submit" class="btn btn-warning">⚠️ Reabrir Evento</button>
