  <!-- ============================================================ -->
  <script is:inline define:vars={{ API_BASE }}>
    (function() {
      'use strict';

      // ============================================================
      // STATE
      // ============================================================
      const state = {
        token: localStorage.getItem('feriaapp_token'),
        user: null,
        currentView: 'resumen',
        eventos: [],
        ventas: [],
        bodega: [],
        auditoria: []
      };

      // ============================================================
      // DOM HELPERS
      // ============================================================
      const $ = (s) => document.querySelector(s);
      const $$ = (s) => document.querySelectorAll(s);

      const fmtDate = (d) => d ? new Date(d).toLocaleDateString('es-CL', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      }) : '--';

      const fmtTime = (d) => d ? new Date(d).toLocaleTimeString('es-CL', {
        hour: '2-digit',
        minute: '2-digit'
      }) : '--';

      const fmtDateTime = (d) => d ? `${fmtDate(d)} ${fmtTime(d)}` : '--';

      const fmtCur = (a) => a != null ? '$' + Number(a).toLocaleString('es-CL') : '--';

      const escapeHtml = (text) => {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      };

      // ============================================================
      // API
      // ============================================================
      const api = async (ep, opts = {}) => {
        try {
          const res = await fetch(API_BASE + ep, {
            headers: {
              'Content-Type': 'application/json',
              ...(state.token ? { 'Authorization': 'Bearer ' + state.token } : {}),
              ...opts.headers
            },
            ...opts,
            body: opts.body && typeof opts.body === 'object' ? JSON.stringify(opts.body) : opts.body
          });

          const data = await res.json().catch(() => null);

          if (res.status === 401) {
            // Token inválido o expirado
            localStorage.removeItem('feriaapp_token');
            localStorage.removeItem('feriaapp_user');
            showLogin();
            return null;
          }

          return { ok: res.ok, status: res.status, data };
        } catch (e) {
          console.error('API Error:', e);
          updateApiStatus(false);
          return { ok: false, error: e.message };
        }
      };

      // ============================================================
      // AUTH
      // ============================================================
      const login = async (em, pw) => {
        const r = await api('/auth/login', {
          method: 'POST',
          body: { email: em, password: pw }
        });

        if (r?.ok && r.data?.token) {
          state.token = r.data.token;
          state.user = r.data.user || { nombre: 'Admin' };
          localStorage.setItem('feriaapp_token', r.data.token);
          if (r.data.user) {
            localStorage.setItem('feriaapp_user', JSON.stringify(r.data.user));
          }
          return true;
        }
        return false;
      };

      const logout = () => {
        state.token = null;
        state.user = null;
        localStorage.removeItem('feriaapp_token');
        localStorage.removeItem('feriaapp_user');
        showLogin();
      };

      const checkAuth = () => {
        const t = localStorage.getItem('feriaapp_token');
        const u = localStorage.getItem('feriaapp_user');

        if (t) {
          state.token = t;
          try {
            state.user = JSON.parse(u);
          } catch (e) {
            state.user = { nombre: 'Admin' };
          }
          return true;
        }
        return false;
      };

      const showLogin = () => {
        $('#admin-loading')?.classList.add('hidden');
        $('#admin-login')?.classList.remove('hidden');
        $('#admin-dashboard')?.classList.add('hidden');
      };

      const showDashboard = () => {
        $('#admin-loading')?.classList.add('hidden');
        $('#admin-login')?.classList.add('hidden');
        $('#admin-dashboard')?.classList.remove('hidden');

        const u = state.user;
        if (u) {
          const ne = $('#user-name');
          const ae = $('#user-avatar');
          if (ne) ne.textContent = u.nombre || u.email || 'Admin';
          if (ae) ae.textContent = (u.nombre?.[0] || u.email?.[0] || 'A').toUpperCase();
        }

        loadDashboardData();
      };

      // ============================================================
      // API STATUS
      // ============================================================
      const updateApiStatus = (on) => {
        const el = $('#api-status');
        const dot = el?.querySelector('.status-dot');
        if (el && dot) {
          dot.classList.toggle('offline', !on);
          const textNode = el.childNodes[2];
          if (textNode) textNode.textContent = on ? ' Conectado' : ' Offline';
        }
      };

      // ============================================================
      // NAVIGATION
      // ============================================================
      const switchView = (vn) => {
        state.currentView = vn;

        $$('.nav-item').forEach(b => {
          b.classList.toggle('active', b.dataset.view === vn);
        });

        const titles = {
          resumen: 'Resumen',
          eventos: 'Eventos',
          ventas: 'Ventas',
          bodega: 'Bodega',
          historico: 'Histórico y Auditoría'
        };
        const te = $('#view-title');
        if (te) te.textContent = titles[vn] || vn;

        $$('.admin-view').forEach(v => v.classList.add('hidden'));
        const ve = $(`#view-${vn}`);
        if (ve) ve.classList.remove('hidden');

        // Cargar datos según vista
        if (vn === 'eventos') loadEventos();
        if (vn === 'ventas') loadVentas();
        if (vn === 'bodega') loadBodega();
        if (vn === 'historico') loadHistorico();
        if (vn === 'resumen') loadDashboardData();

        closeSidebar();
      };

      // ============================================================
      // SIDEBAR
      // ============================================================
      const openSidebar = () => {
        $('#admin-sidebar')?.classList.add('is-open');
        $('#admin-overlay')?.classList.add('is-visible');
      };

      const closeSidebar = () => {
        $('#admin-sidebar')?.classList.remove('is-open');
        $('#admin-overlay')?.classList.remove('is-visible');
      };

      // ============================================================
      // DASHBOARD DATA
      // ============================================================
      const loadDashboardData = async () => {
        const h = await api('/health');
        updateApiStatus(h?.ok);
        await Promise.all([
          loadEventosStats(),
          loadBodegaStats(),
          loadVentasStats()
        ]);
        loadResumenEventos();
        loadResumenVentas();
      };

      const loadEventosStats = async () => {
        const r = await api('/eventos?estado=activo&limit=1');
        if (r?.ok) {
          const total = r.data?.total || r.data?.length || 0;
          const el = $('#stat-eventos');
          if (el) el.textContent = total;
        }
      };

      const loadBodegaStats = async () => {
        const r = await api('/productos/bodega?limit=1');
        if (r?.ok) {
          const total = r.data?.total || r.data?.length || 0;
          const el = $('#stat-bodega');
          if (el) el.textContent = total;
        }
      };

      const loadVentasStats = async () => {
        const now = new Date();
        const fd = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
        const r = await api(`/ventas?fecha_desde=${fd}&limit=1`);

        if (r?.ok) {
          const data = r.data?.items || r.data || [];
          const totalVentas = r.data?.total || data.length || 0;
          const ingresos = data.reduce((s, v) => s + (v.total_venta || v.total || 0), 0);

          const elVentas = $('#stat-ventas');
          const elIngresos = $('#stat-ingresos');

          if (elVentas) elVentas.textContent = totalVentas;
          if (elIngresos) elIngresos.textContent = fmtCur(ingresos);
        }
      };

      // ============================================================
      // RESUMEN - Eventos Recientes
      // ============================================================
      const loadResumenEventos = async () => {
        const r = await api('/eventos?limit=5');
        const tb = $('#resumen-eventos-tbody');
        if (!tb) return;

        if (!r?.ok || !r.data?.length) {
          tb.innerHTML = '<tr><td colspan="4" class="empty-state">No hay eventos registrados</td></tr>';
          return;
        }

        tb.innerHTML = r.data.slice(0, 5).map(e => {
          const ec = e.estado === 'activo' ? 'badge-success' :
            e.estado === 'cerrado' ? 'badge-danger' : 'badge-warning';
          const total = e.total_recaudado || e.total_confirmado || e.total_calculado || 0;
          return `<tr>
            <td><strong>${escapeHtml(e.nombre || e.lugar || 'Sin nombre')}</strong></td>
            <td>${fmtDate(e.fecha)}</td>
            <td><span class="badge ${ec}">${e.estado || 'N/A'}</span></td>
            <td>${fmtCur(total)}</td>
          </tr>`;
        }).join('');
      };

      // ============================================================
      // RESUMEN - Ventas Recientes
      // ============================================================
      const loadResumenVentas = async () => {
        const r = await api('/ventas?limit=5');
        const tb = $('#resumen-ventas-tbody');
        if (!tb) return;

        if (!r?.ok || !r.data?.length) {
          tb.innerHTML = '<tr><td colspan="4" class="empty-state">No hay ventas registradas</td></tr>';
          return;
        }

        tb.innerHTML = r.data.slice(0, 5).map(v => {
          const total = v.total_venta || v.total || 0;
          const items = v.lineas?.length || v.cantidad_items || 0;
          const evento = v.evento_lugar || v.evento_nombre || 'N/A';
          const fecha = v.timestamp_local || v.fecha;
          return `<tr>
            <td>${fmtDate(fecha)}</td>
            <td>${escapeHtml(evento)}</td>
            <td><strong>${fmtCur(total)}</strong></td>
            <td>${items}</td>
          </tr>`;
        }).join('');
      };

      // ============================================================
      // EVENTOS
      // ============================================================
      const loadEventos = async () => {
        const r = await api('/eventos?limit=100');
        const tb = $('#eventos-tbody');
        if (!tb) return;

        state.eventos = r?.data || [];

        if (!state.eventos.length) {
          tb.innerHTML = '<tr><td colspan="6" class="empty-state">No hay eventos. Crea el primero.</td></tr>';
          return;
        }

        renderEventos(state.eventos);
      };

      const renderEventos = (evs) => {
        const tb = $('#eventos-tbody');
        if (!tb) return;

        tb.innerHTML = evs.map(e => {
          const ec = e.estado === 'activo' ? 'badge-success' :
            e.estado === 'cerrado' ? 'badge-danger' : 'badge-warning';
          const pc = e.estado === 'activo';
          const total = e.total_recaudado || e.total_confirmado || e.total_calculado || 0;
          const canal = e.canal_venta_nombre ?
            `<br><small style="color:var(--color-muted)">${escapeHtml(e.canal_venta_nombre)}</small>` :
            '';

          return `<tr data-id="${e.id}">
            <td><strong>${escapeHtml(e.nombre || e.lugar || 'Sin nombre')}</strong>${canal}</td>
            <td>${fmtDate(e.fecha)}</td>
            <td>${escapeHtml(e.lugar || '--')}</td>
            <td><span class="badge ${ec}">${e.estado || 'N/A'}</span></td>
            <td>${fmtCur(total)}</td>
            <td>
              <div style="display:flex;gap:4px;flex-wrap:wrap;">
                ${pc ? `<button class="btn btn-sm btn-danger" data-action="cerrar" data-id="${e.id}">Cerrar</button>` : ''}
                ${e.estado === 'cerrado' ? `<button class="btn btn-sm btn-warning" data-action="reabrir" data-id="${e.id}" data-nombre="${escapeHtml(e.nombre || e.lugar || 'Evento')}">🔓 Reabrir</button>` : ''}
                <button class="btn btn-sm btn-outline" data-action="editar" data-id="${e.id}">Editar</button>
              </div>
            </td>
          </tr>`;
        }).join('');

        // Event listeners para acciones
        tb.querySelectorAll('[data-action="cerrar"]').forEach(btn => {
          btn.addEventListener('click', () => cerrarEvento(btn.dataset.id));
        });

        tb.querySelectorAll('[data-action="reabrir"]').forEach(btn => {
          btn.addEventListener('click', () => {
            document.getElementById('reabrir-evento-id').value = btn.dataset.id;
            document.getElementById('reabrir-evento-nombre').value = btn.dataset.nombre;
            document.getElementById('modal-reabrir').showModal();
          });
        });

        tb.querySelectorAll('[data-action="editar"]').forEach(btn => {
          btn.addEventListener('click', () => {
            alert('✏️ Editar evento #' + btn.dataset.id + ' - En desarrollo');
          });
        });
      };

      // ============================================================
      // CERRAR EVENTO
      // ============================================================
      const cerrarEvento = async (id) => {
        const total = prompt('Ingresa el total confirmado para el cierre:');
        if (total === null) return;
        const totalNum = Number(total);
        if (isNaN(totalNum) || totalNum < 0) {
          alert('Debes ingresar un número válido.');
          return;
        }

        const confirmar = confirm(`¿Cerrar evento #${id} con total $${totalNum.toLocaleString()}?`);
        if (!confirmar) return;

        const r = await api(`/eventos/${id}/cerrar`, {
          method: 'POST',
          body: { total_confirmado: totalNum }
        });

        if (r?.ok) {
          alert('✅ Evento cerrado exitosamente');
          loadEventos();
          loadDashboardData();
        } else {
          alert('❌ Error: ' + (r?.data?.detail || 'Error desconocido'));
        }
      };

      // ============================================================
      // REABRIR EVENTO (con justificación)
      // ============================================================
      document.getElementById('form-reabrir')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const id = document.getElementById('reabrir-evento-id').value;
        const motivo = document.getElementById('reabrir-motivo').value.trim();
        const notaAdicional = document.getElementById('reabrir-nota-adicional').value.trim();

        if (!motivo) {
          alert('⚠️ Debes escribir el motivo de la reapertura.');
          return;
        }

        if (!confirm(`¿Estás seguro de reabrir el evento #${id}?\n\nMotivo: ${motivo}`)) return;

        const payload = {
          nota_reapertura: motivo,
          nota_adicional: notaAdicional || null
        };

        const r = await api(`/eventos/${id}/reabrir`, {
          method: 'POST',
          body: payload
        });

        if (r?.ok) {
          alert('✅ Evento reabierto exitosamente. La justificación ha sido registrada en auditoría.');
          document.getElementById('modal-reabrir').close();
          document.getElementById('form-reabrir').reset();
          loadEventos();
          loadDashboardData();
          // Si estamos en histórico, recargar auditoría
          if (state.currentView === 'historico') loadAuditoria();
        } else {
          alert('❌ Error al reabrir: ' + (r?.data?.detail || 'Error desconocido'));
        }
      });

      // ============================================================
      // VENTAS
      // ============================================================
      const loadVentas = async () => {
        const desde = document.getElementById('filtro-fecha-desde')?.value || '';
        const hasta = document.getElementById('filtro-fecha-hasta')?.value || '';
        const eventoId = document.getElementById('filtro-evento-venta')?.value || '';

        let url = '/ventas?limit=100';
        if (desde) url += `&fecha_desde=${desde}`;
        if (hasta) url += `&fecha_hasta=${hasta}`;
        if (eventoId) url += `&evento_id=${eventoId}`;

        const r = await api(url);
        const tb = $('#ventas-tbody');
        if (!tb) return;

        state.ventas = r?.data || [];

        // Cargar eventos en filtro
        if (!document.querySelector('#filtro-evento-venta option[value=""]')) {
          const evRes = await api('/eventos?limit=100');
          if (evRes?.ok) {
            const select = document.getElementById('filtro-evento-venta');
            select.innerHTML = '<option value="">Todos los eventos</option>' +
              evRes.data.map(e => `<option value="${e.id}">${escapeHtml(e.nombre || e.lugar || 'Sin nombre')}</option>`).join('');
          }
        }

        if (!state.ventas.length) {
          tb.innerHTML = '<tr><td colspan="7" class="empty-state">No hay ventas registradas</td></tr>';
          return;
        }

        renderVentas(state.ventas);
      };

      const renderVentas = (vs) => {
        const tb = $('#ventas-tbody');
        if (!tb) return;

        tb.innerHTML = vs.map(v => {
          const total = v.total_venta || v.total || 0;
          const items = v.lineas?.length || v.cantidad_items || 0;
          const metodo = v.forma_pago || '--';
          const evento = v.evento_lugar || v.evento_nombre || 'N/A';
          const fecha = v.timestamp_local || v.fecha;

          return `<tr>
            <td><code>#${v.id}</code></td>
            <td>${fmtDate(fecha)}</td>
            <td>${escapeHtml(evento)}</td>
            <td>${items}</td>
            <td><strong>${fmtCur(total)}</strong></td>
            <td>${escapeHtml(metodo)}</td>
            <td><small>${escapeHtml((v.notas || '').substring(0, 30))}</small></td>
          </tr>`;
        }).join('');
      };

      // ============================================================
      // BODEGA
      // ============================================================
      const loadBodega = async () => {
        const r = await api('/productos/bodega?limit=200');
        const tb = $('#bodega-tbody');
        if (!tb) return;

        state.bodega = r?.data || [];

        if (!state.bodega.length) {
          tb.innerHTML = '<tr><td colspan="7" class="empty-state">Bodega vacía. Agrega productos.</td></tr>';
          return;
        }

        renderBodega(state.bodega);
      };

      const renderBodega = (ps) => {
        const tb = $('#bodega-tbody');
        if (!tb) return;

        tb.innerHTML = ps.map(p => {
          const stock = p.stock || 0;
          const sb = stock < 5 && stock > 0;
          const ag = stock === 0;
          const ec = ag ? 'badge-danger' : sb ? 'badge-warning' : 'badge-success';
          const et = ag ? 'Agotado' : sb ? 'Stock Bajo' : 'Disponible';

          const historia = p.historia_origen ?
            `<br><small style="color: var(--feria-gold); font-style: italic;">📖 ${escapeHtml(p.historia_origen.substring(0, 40))}${p.historia_origen.length > 40 ? '...' : ''}</small>` :
            '';

          return `<tr data-id="${p.id}">
            <td><code style="font-size:0.75rem;">${escapeHtml(p.sku || p.codigo_barras || p.id)}</code></td>
            <td>
              <strong>${escapeHtml(p.nombre || 'Sin nombre')}</strong>
              ${historia}
            </td>
            <td>${escapeHtml(p.categoria_feriaapp_nombre || p.categoria_revistete_nombre || '--')}</td>
            <td>${stock}</td>
            <td>${fmtCur(p.precio_final || p.precio_feria || p.precio_standard || 0)}</td>
            <td><span class="badge ${ec}">${et}</span></td>
            <td>
              <button class="btn btn-sm btn-outline" data-action="editar-producto" data-id="${p.id}">Editar</button>
              ${p.historia_origen ? `<button class="btn btn-sm btn-outline" data-action="ver-historia" data-id="${p.id}" style="font-size:0.7rem;">📖</button>` : ''}
            </td>
          </tr>`;
        }).join('');

        tb.querySelectorAll('[data-action="editar-producto"]').forEach(btn => {
          btn.addEventListener('click', () => {
            window.location.href = `/?editar=${btn.dataset.id}`;
          });
        });

        tb.querySelectorAll('[data-action="ver-historia"]').forEach(btn => {
          btn.addEventListener('click', () => {
            const p = state.bodega.find(item => String(item.id) === btn.dataset.id);
            if (p?.historia_origen) {
              alert(`📖 Historia de "${p.nombre}"
━━━━━━━━━━━━━━━━━━━━━━━
${p.historia_origen}
${p.historia_ubicacion ? `\n📍 ${p.historia_ubicacion}` : ''}
${p.historia_motivo ? `\n💡 Motivo: ${p.historia_motivo}` : ''}`);
            } else {
              alert('Esta prenda aún no tiene historia registrada.');
            }
          });
        });
      };

      // ============================================================
      // HISTÓRICO / AUDITORÍA
      // ============================================================
      const loadHistorico = () => {
        // Activar pestaña por defecto
        document.querySelectorAll('.historico-tabs .tab-btn').forEach(btn => {
          btn.classList.remove('active');
        });
        const firstTab = document.querySelector('.historico-tabs .tab-btn');
        if (firstTab) firstTab.classList.add('active');

        document.querySelectorAll('.historico-tabs + .tab-panel').forEach(p => p.classList.add('hidden'));
        const firstPanel = document.querySelector('.historico-tabs + .tab-panel');
        if (firstPanel) firstPanel.classList.remove('hidden');

        loadAuditoria();
        loadEventosCerrados();
        loadFlujos();
      };

      // ============================================================
      // AUDITORÍA
      // ============================================================
      const loadAuditoria = async () => {
        const tb = document.getElementById('historico-auditoria-tbody');
        if (!tb) return;

        const texto = document.getElementById('filtro-auditoria')?.value || '';
        const tipo = document.getElementById('filtro-auditoria-tipo')?.value || '';
        const desde = document.getElementById('filtro-auditoria-desde')?.value || '';
        const hasta = document.getElementById('filtro-auditoria-hasta')?.value || '';

        let url = `/auditoria?limit=100`;
        if (texto) url += `&search=${encodeURIComponent(texto)}`;
        if (tipo) url += `&tipo=${tipo}`;
        if (desde) url += `&fecha_desde=${desde}`;
        if (hasta) url += `&fecha_hasta=${hasta}`;

        const r = await api(url);
        if (!r?.ok || !r.data?.length) {
          tb.innerHTML = '<tr><td colspan="5" class="empty-state">No hay registros de auditoría</td></tr>';
          return;
        }

        state.auditoria = r.data;

        tb.innerHTML = r.data.map(a => {
          const tipoLabel = a.tipo || '--';
          const tipoClass = tipoLabel === 'reabrir' ? 'badge-warning' :
            tipoLabel === 'modificar' ? 'badge-info' :
            tipoLabel === 'stock' ? 'badge-danger' : 'badge-success';

          return `<tr>
            <td>${fmtDateTime(a.created_at || a.fecha_cambio)}</td>
            <td><span class="badge ${tipoClass}">${tipoLabel}</span></td>
            <td>${escapeHtml(a.usuario_nombre || a.operador || '--')}</td>
            <td>${escapeHtml(a.detalle || a.campo_afectado || '--')}</td>
            <td><small><em>${escapeHtml(a.justificacion || a.motivo || '--')}</em></small></td>
          </tr>`;
        }).join('');
      };

      // ============================================================
      // EVENTOS CERRADOS
      // ============================================================
      const loadEventosCerrados = async () => {
        const tb = document.getElementById('historico-eventos-tbody');
        if (!tb) return;

        const texto = document.getElementById('filtro-eventos-cerrados')?.value || '';
        const desde = document.getElementById('filtro-eventos-desde')?.value || '';
        const hasta = document.getElementById('filtro-eventos-hasta')?.value || '';

        let url = `/eventos?estado=cerrado&limit=100`;
        if (texto) url += `&search=${encodeURIComponent(texto)}`;
        if (desde) url += `&fecha_desde=${desde}`;
        if (hasta) url += `&fecha_hasta=${hasta}`;

        const r = await api(url);
        if (!r?.ok || !r.data?.length) {
          tb.innerHTML = '<tr><td colspan="7" class="empty-state">No hay eventos cerrados</td></tr>';
          return;
        }

        tb.innerHTML = r.data.map(e => {
          const diff = (e.diferencia || 0) !== 0;
          return `<tr data-id="${e.id}">
            <td><strong>${escapeHtml(e.nombre || e.lugar || 'Sin nombre')}</strong></td>
            <td>${fmtDate(e.fecha)}</td>
            <td>${fmtCur(e.total_calculado || 0)}</td>
            <td>${fmtCur(e.total_confirmado || 0)}</td>
            <td class="${diff ? 'text-danger' : ''}">${fmtCur(e.diferencia || 0)}</td>
            <td>${fmtDate(e.fecha_cierre)}</td>
            <td>
              <button class="btn btn-sm btn-warning btn-reabrir" data-id="${e.id}" data-nombre="${escapeHtml(e.nombre || e.lugar || 'Evento')}">🔓 Reabrir</button>
            </td>
          </tr>`;
        }).join('');

        tb.querySelectorAll('.btn-reabrir').forEach(btn => {
          btn.addEventListener('click', () => {
            document.getElementById('reabrir-evento-id').value = btn.dataset.id;
            document.getElementById('reabrir-evento-nombre').value = btn.dataset.nombre;
            document.getElementById('modal-reabrir').showModal();
          });
        });
      };

      // ============================================================
      // FLUJOS DE PRODUCTOS
      // ============================================================
      const loadFlujos = async () => {
        const tb = document.getElementById('historico-flujos-tbody');
        if (!tb) return;

        const texto = document.getElementById('filtro-flujos')?.value || '';
        const tipo = document.getElementById('filtro-flujo-tipo')?.value || '';
        const estado = document.getElementById('filtro-flujo-estado')?.value || '';

        let url = `/productos/flujos?limit=100`;
        if (texto) url += `&search=${encodeURIComponent(texto)}`;
        if (tipo) url += `&tipo=${tipo}`;
        if (estado) url += `&estado=${estado}`;

        const r = await api(url);
        if (!r?.ok || !r.data?.length) {
          tb.innerHTML = '<tr><td colspan="6" class="empty-state">No hay flujos registrados</td></tr>';
          return;
        }

        tb.innerHTML = r.data.map(f => {
          const tipoLabel = f.tipo || '--';
          const tipoClass = tipoLabel === 'boutique' ? 'badge-success' :
            tipoLabel === 'feria' ? 'badge-warning' :
            tipoLabel === 'donacion' ? 'badge-info' : 'badge-danger';

          return `<tr>
            <td><strong>${escapeHtml(f.producto_nombre || 'Sin nombre')}</strong></td>
            <td><span class="badge ${tipoClass}">${tipoLabel}</span></td>
            <td>${fmtDate(f.fecha_movimiento || f.created_at)}</td>
            <td>${escapeHtml(f.motivo || '--')}</td>
            <td>${escapeHtml(f.evaluado_por || '--')}</td>
            <td><small>${escapeHtml((f.historia_origen || '').substring(0, 60))}${(f.historia_origen || '').length > 60 ? '...' : ''}</small></td>
          </tr>`;
        }).join('');
      };

      // ============================================================
      // FILTROS (eventos en tiempo real)
      // ============================================================
      // Eventos
      document.getElementById('filtro-eventos')?.addEventListener('input', (e) => {
        const q = e.target.value.toLowerCase();
        const filtered = state.eventos.filter(ev =>
          (ev.nombre || '').toLowerCase().includes(q) ||
          (ev.lugar || '').toLowerCase().includes(q)
        );
        renderEventos(filtered);
      });

      document.getElementById('filtro-estado')?.addEventListener('change', (e) => {
        const st = e.target.value;
        const filtered = st ? state.eventos.filter(ev => ev.estado === st) : state.eventos;
        renderEventos(filtered);
      });

      // Ventas
      document.getElementById('filtro-fecha-desde')?.addEventListener('change', loadVentas);
      document.getElementById('filtro-fecha-hasta')?.addEventListener('change', loadVentas);
      document.getElementById('filtro-evento-venta')?.addEventListener('change', loadVentas);

      // Bodega
      document.getElementById('filtro-bodega')?.addEventListener('input', (e) => {
        const q = e.target.value.toLowerCase();
        const filtered = state.bodega.filter(p =>
          (p.nombre || '').toLowerCase().includes(q) ||
          (p.sku || '').toLowerCase().includes(q)
        );
        renderBodega(filtered);
      });

      document.getElementById('filtro-stock')?.addEventListener('change', (e) => {
        const t = e.target.value;
        let filtered = state.bodega;
        if (t === 'bajo') filtered = state.bodega.filter(p => (p.stock || 0) < 5 && (p.stock || 0) > 0);
        if (t === 'agotado') filtered = state.bodega.filter(p => (p.stock || 0) === 0);
        renderBodega(filtered);
      });

      // Auditoría
      document.getElementById('filtro-auditoria')?.addEventListener('input', loadAuditoria);
      document.getElementById('filtro-auditoria-tipo')?.addEventListener('change', loadAuditoria);
      document.getElementById('filtro-auditoria-desde')?.addEventListener('change', loadAuditoria);
      document.getElementById('filtro-auditoria-hasta')?.addEventListener('change', loadAuditoria);

      // Eventos cerrados
      document.getElementById('filtro-eventos-cerrados')?.addEventListener('input', loadEventosCerrados);
      document.getElementById('filtro-eventos-desde')?.addEventListener('change', loadEventosCerrados);
      document.getElementById('filtro-eventos-hasta')?.addEventListener('change', loadEventosCerrados);

      // Flujos
      document.getElementById('filtro-flujos')?.addEventListener('input', loadFlujos);
      document.getElementById('filtro-flujo-tipo')?.addEventListener('change', loadFlujos);
      document.getElementById('filtro-flujo-estado')?.addEventListener('change', loadFlujos);

      // ============================================================
      // BOTONES Y ACCIONES GLOBALES
      // ============================================================
      // Navegación desde botones de resumen
      document.querySelectorAll('[data-action="ver-eventos"], [data-action="ver-ventas"]').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.action === 'ver-eventos' ? 'eventos' : 'ventas';
          switchView(target);
        });
      });

      // Nuevo evento
      document.getElementById('btn-nuevo-evento')?.addEventListener('click', () => {
        document.getElementById('modal-evento-title').textContent = 'Nuevo Evento';
        document.getElementById('evento-id').value = '';
        document.getElementById('form-evento').reset();
        document.getElementById('modal-evento').showModal();
      });

      // Formulario de evento
      document.getElementById('form-evento')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const btn = e.target.querySelector('button[type="submit"]');
        const txt = btn?.querySelector('.btn-text');
        const sp = btn?.querySelector('.btn-spinner');
        if (txt) txt.classList.add('hidden');
        if (sp) sp.classList.remove('hidden');
        if (btn) btn.disabled = true;

        const payload = {
          nombre: document.getElementById('evento-nombre').value,
          fecha: document.getElementById('evento-fecha').value,
          hora: document.getElementById('evento-hora').value || null,
          ubicacion: document.getElementById('evento-ubicacion').value || null,
          descripcion: document.getElementById('evento-descripcion').value || null
        };

        const r = await api('/eventos', {
          method: 'POST',
          body: payload
        });

        if (txt) txt.classList.remove('hidden');
        if (sp) sp.classList.add('hidden');
        if (btn) btn.disabled = false;

        if (r?.ok) {
          document.getElementById('modal-evento').close();
          loadEventos();
          loadDashboardData();
          alert('✅ Evento creado exitosamente');
        } else {
          alert('❌ Error: ' + (r?.data?.detail || 'Error desconocido'));
        }
      });

      // Cerrar modales
      document.querySelectorAll('[data-close-modal]').forEach(btn => {
        btn.addEventListener('click', () => {
          const modal = btn.closest('dialog');
          if (modal) modal.close();
        });
      });

      // Cerrar modal al hacer click fuera
      document.querySelectorAll('.admin-modal').forEach(modal => {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) modal.close();
        });
      });

      // ============================================================
      // TABS DEL HISTÓRICO
      // ============================================================
      document.querySelectorAll('.historico-tabs .tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.historico-tabs .tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          document.querySelectorAll('.historico-tabs + .tab-panel, .historico-tabs ~ .tab-panel').forEach(p => p.classList.add('hidden'));

          const panelId = 'panel-' + btn.dataset.tab;
          const panel = document.getElementById(panelId);
          if (panel) panel.classList.remove('hidden');

          // Cargar datos según pestaña
          const tab = btn.dataset.tab;
          if (tab === 'auditoria') loadAuditoria();
          if (tab === 'eventos-cerrados') loadEventosCerrados();
          if (tab === 'flujos') loadFlujos();
        });
      });

      // ============================================================
      // REFRESH AUDITORÍA
      // ============================================================
      document.getElementById('btn-refresh-auditoria')?.addEventListener('click', () => {
        loadAuditoria();
        loadEventosCerrados();
        loadFlujos();
      });

      // ============================================================
      // EXPORTAR AUDITORÍA
      // ============================================================
      document.getElementById('btn-exportar-auditoria')?.addEventListener('click', () => {
        if (!state.auditoria || !state.auditoria.length) {
          alert('No hay datos para exportar.');
          return;
        }

        let csv = 'Fecha,Tipo,Usuario,Detalle,Justificación\n';
        state.auditoria.forEach(a => {
          const fecha = fmtDateTime(a.created_at || a.fecha_cambio);
          const tipo = a.tipo || '--';
          const usuario = a.usuario_nombre || a.operador || '--';
          const detalle = (a.detalle || a.campo_afectado || '--').replace(/,/g, ';');
          const justificacion = (a.justificacion || a.motivo || '--').replace(/,/g, ';');
          csv += `${fecha},${tipo},${usuario},${detalle},${justificacion}\n`;
        });

        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `auditoria_${new Date().toISOString().split('T')[0]}.csv`;
        link.click();
        URL.revokeObjectURL(link.href);
      });

      // ============================================================
      // NUEVO PRODUCTO
      // ============================================================
      document.getElementById('btn-nuevo-producto')?.addEventListener('click', () => {
        window.location.href = '/?nuevo=1';
      });

      // ============================================================
      // NUEVA VENTA
      // ============================================================
      document.getElementById('btn-nueva-venta')?.addEventListener('click', () => {
        alert('🧾 Registrar nueva venta - En desarrollo');
        // Aquí iría el modal/formulario de venta
      });

      // ============================================================
      // LOGOUT
      // ============================================================
      document.getElementById('btn-logout')?.addEventListener('click', logout);

      // ============================================================
      // SIDEBAR TOGGLE
      // ============================================================
      document.getElementById('sidebar-toggle')?.addEventListener('click', openSidebar);
      document.getElementById('sidebar-close')?.addEventListener('click', closeSidebar);
      document.getElementById('admin-overlay')?.addEventListener('click', closeSidebar);

      // ============================================================
      // NAVEGACIÓN POR TECLADO (Escape para cerrar sidebar)
      // ============================================================
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeSidebar();
          document.querySelectorAll('.admin-modal[open]').forEach(m => m.close());
        }
      });

      // ============================================================
      // INICIALIZACIÓN
      // ============================================================
      const init = () => {
        if (checkAuth()) {
          showDashboard();
        } else {
          showLogin();
        }

        // Login
        document.getElementById('login-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          document.getElementById('login-error')?.classList.add('hidden');

          const btn = e.target.querySelector('button[type="submit"]');
          const txt = btn?.querySelector('.btn-text');
          const sp = btn?.querySelector('.btn-spinner');
          if (txt) txt.classList.add('hidden');
          if (sp) sp.classList.remove('hidden');
          if (btn) btn.disabled = true;

          const email = document.getElementById('login-email').value.trim();
          const password = document.getElementById('login-password').value;
          const ok = await login(email, password);

          if (txt) txt.classList.remove('hidden');
          if (sp) sp.classList.add('hidden');
          if (btn) btn.disabled = false;

          if (ok) {
            showDashboard();
          } else {
            const le = document.getElementById('login-error');
            if (le) {
              le.textContent = 'Email o contraseña incorrectos.';
              le.classList.remove('hidden');
            }
          }
        });

        // Navegación
        $$('.nav-item').forEach(b => {
          b.addEventListener('click', () => switchView(b.dataset.view));
        });
      };

      // Iniciar cuando el DOM esté listo
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }

    })();
  </script>
</Layout>
